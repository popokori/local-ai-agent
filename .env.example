# Copier en .env (ne pas commit) et adapter
SPRING_PROFILES_ACTIVE=dev

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=localaiagent
DB_USER=localaiagent
DB_PASS=change_me

# --- Security ---
# Doit faire >= 32 caractères en prod (sera vérifié au démarrage)
JWT_SECRET=please_change_me_to_a_random_32_chars_minimum_secret

# --- Frontend ---
FRONT_ORIGIN=http://localhost:4200

# --- LLM (Ollama par défaut en Phase 1, CPU only) ---
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_NATIVE_BASE_URL=http://localhost:11434
LLM_API_KEY=
LLM_DEFAULT_MODEL=llama3.1:8b
# Alternatives :
#   qwen2.5:7b-instruct
#   mistral:7b-instruct
#   qwen2.5:14b-instruct
LLM_EXPERT_MODEL=llama3.1:8b
LLM_FACT_MODEL=llama3.1:8b
